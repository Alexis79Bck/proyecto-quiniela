# ===========================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ===========================================
APP_NAME="Quiniela FIFA 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
BOOST_ENABLED=true
APP_URL=http://localhost:8000

# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================

# Opción A: PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=quiniela_fifa_2026_db
DB_USERNAME=<Tu_Nombre_Usuario>
DB_PASSWORD=<Tu_Contraseña>

# Opción B: SQLite (comentar MySQL y descomentar esto)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/FIFAWC2026.sqlite

# ===========================================
# CONFIGURACIÓN DE SESIÓN Y CACHÉ
# ===========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
# QUEUE_CONNECTION=database

# ===========================================
# CONFIGURACIÓN DE REDIS (OPCIONAL)
# ===========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# CONFIGURACIÓN DE MAIL
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@quiniela-fifa2026.com"
MAIL_FROM_NAME="${APP_NAME}"

# Pusher Configuration
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_ID=
PUSHER_APP_CLUSTER=us2

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ===========================================
# CONFIGURACIÓN DE PUSHER (NOTIFICACIONES)
# ===========================================
# Pusher configuration removed - notification system migrated
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_ID=
# PUSHER_APP_CLUSTER=
#
# BROADCAST_DRIVER=
# VITE_PUSHER_APP_KEY=
# VITE_PUSHER_APP_CLUSTER=

# ===========================================
# CONFIGURACIÓN DE LOGGING
# ===========================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=90

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ===========================================
# CONFIGURACIÓN DE SANCTUM
# ===========================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
SANCTUM_EXPIRATION=60